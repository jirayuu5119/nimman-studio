# Public browser configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://grad.jirayufoto.net

# Server-only configuration
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RATE_LIMIT_HASH_SECRET=
CRON_SECRET=

# Temporary ISO-8601 cutoff for exchanging legacy URL tokens into cookies.
# Remove after the migration window.
LEGACY_BOOKING_TOKEN_ACCEPT_UNTIL=

# Optional destructive cleanup. Leave empty to disable orphan slip deletion.
ORPHAN_SLIP_RETENTION_HOURS=

# Optional privacy retention. Completed/cancelled bookings older than this
# number of days are anonymized in batches. Allowed range: 365-3650.
CUSTOMER_DATA_RETENTION_DAYS=
